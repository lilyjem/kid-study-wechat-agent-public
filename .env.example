# Copy this file to .env or export these variables in your runtime environment.

# Required: recipient email for parent/guardian alerts
ALERT_EMAIL_TO=parent@example.com

# Optional: path to the SMTP helper script.
# If unset, the repository defaults to scripts/send_email.py
# SMTP_SEND_SCRIPT=/absolute/path/to/send_email.py

# Optional: customize the subject prefix for alert emails
ALERT_SUBJECT_PREFIX=[Child Risk Alert]

# SMTP settings for scripts/send_email.py (or any compatible helper)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com
SMTP_USE_SSL=false
