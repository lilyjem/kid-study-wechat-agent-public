# Copy this file to .env or export these variables in your runtime environment.

# Required: recipient email for parent/guardian alerts
ALERT_EMAIL_TO=parent@example.com

# Required: path to the SMTP helper script available on the host machine
SMTP_SEND_SCRIPT=/path/to/send_email.py

# Optional: customize the subject prefix for alert emails
ALERT_SUBJECT_PREFIX=[儿童风险提醒]
